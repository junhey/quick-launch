{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quick Launch",
  "version": "0.1.0",
  "identifier": "dev.junhey.quick-launch",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Quick Launch",
        "width": 680,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "shadow": true,
        "acceptFirstMouse": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "category": "Productivity",
    "shortDescription": "Quick Launch - Mac 启动器",
    "longDescription": "Control 呼出面板，按键直达应用/文件夹/网页的开源 Mac 启动器"
  }
}
